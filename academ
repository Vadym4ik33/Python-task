        'discipline': { url: baseUrl + "autocomplete/akada/scheduleDiscipline"}
    };

    function addFilterItem(event, id, label) {
        var filterName = $(event.target).attr('id');

        if(!$('#'+filterName+'_input a[rel='+id+']').length) {
            $('#'+filterName+'_input').append('<span>'+label+' <input type="hidden" name="'+filterName+'[]" value="'+id+'" /> <a class="cancelIco ico" rel="'+id+'" href="javascript:void(0);" title="Удалить">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</a></span>');
        }
        $(event.target).val('');
    }

    function bindAcFields() {
        for(var fidx in tfilters) {
            $('#'+fidx).blur().mcAutocompleteInit(
                    tfilters[fidx]['url'],
                    {},
                    {
                        select: function(event, ui) {
                            addFilterItem(event, ui.item.data['ID'], ui.item.value);
                        },
                        close: function(e) {
                            $('#'+e.target.id).val('');
                        }
                    }
            );
        }
    }

    if(filterLoaded) {
        bindAcFields();
    }

    $('.filter-values span > a').on('click', function() {
        $(this).parent().remove();
    });

    $('#scheduleFilterForm').submit(function() {
        if(($('input[name="employee[]"]').val() === undefined && $('input[name="group[]"]').val() === undefined && $('input[name="discipline[]"]').val() === undefined) && $('input[name=mySchedule]:checked').val() == 2) {
            $('input[name="employee"]').focus();
            return false;
        }
    });

    $('input[name=mySchedule]').click(function () {
        var filterBlock = $('#scheduleFilter');
        if ($(this).val() == '2' && filterBlock.hasClass('hidden')) {
            filterBlock.removeClass('hidden');
            $('.filter_schedule_checkboxes input').prop('checked', true);
        } else {
            filterBlock.addClass('hidden');
        }
    });

</script>

